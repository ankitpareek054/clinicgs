PORT=4000
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_NAME=clinicgs
DB_USER=postgres
DB_PASSWORD=YOUR_POSTGRES_PASSWORD
DB_SSL=false

JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

COOKIE_NAME=clinicgs_token
COOKIE_MAX_AGE_MS=604800000
COOKIE_SECURE=false

CLIENT_ORIGIN=http://localhost:3000,http://localhost:5173
API_BASE_URL=http://localhost:4000

BCRYPT_SALT_ROUNDS=10
INVITE_TOKEN_EXPIRES_HOURS=168

MAIL_ENABLED=false
MAIL_FROM=no-reply@clinicgs.local

MAKE_ENABLED=false
MAKE_TIMEOUT_MS=10000

GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_TIMEOUT_MS=10000